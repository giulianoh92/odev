#!/bin/bash
set -e

# Esperar la resolucion DNS de la base de datos y conectividad TCP.
# depends_on + service_healthy maneja el orden de inicio, pero despues de un
# ciclo down/up el DNS interno de Docker puede no estar listo inmediatamente.
DB_HOST="${HOST:-db}"
DB_PORT=5432
MAX_RETRIES=30
for i in $(seq 1 $MAX_RETRIES); do
    if getent hosts "$DB_HOST" > /dev/null 2>&1 && python3 -c "
import socket, sys
try:
    s = socket.create_connection(('$DB_HOST', $DB_PORT), timeout=2)
    s.close()
except Exception:
    sys.exit(1)
" 2>/dev/null; then
        break
    fi
    echo "Esperando base de datos en $DB_HOST:$DB_PORT... ($i/$MAX_RETRIES)"
    sleep 1
done

if [ "$DEBUGPY" = "True" ]; then
    if ! python3 -c "import debugpy" 2>/dev/null; then
        echo "Instalando debugpy..."
        pip install debugpy -t /tmp/debugpy --no-cache-dir
    fi
    export PYTHONPATH="/tmp/debugpy:${PYTHONPATH:-}"
    CMD="python3"
    ARGS=("-m" "debugpy" "--listen" "0.0.0.0:5678" "/usr/bin/odoo" "--config=/etc/odoo/odoo.conf" "--db-filter=${DB_FILTER}")
else
    CMD="odoo"
    ARGS=("--config=/etc/odoo/odoo.conf" "--db-filter=${DB_FILTER}")
fi

# Funcion auxiliar para verificar si el idioma ya existe
check_language_exists() {
    python3 -c "
import psycopg2
import os
import sys

try:
    conn = psycopg2.connect(
        host=os.environ.get('HOST', 'db'),
        user=os.environ.get('USER', 'odoo'),
        password=os.environ.get('PASSWORD', 'odoo'),
        dbname=os.environ.get('POSTGRES_DB', 'odoo_db')
    )
    cur = conn.cursor()
    cur.execute(\"SELECT 1 FROM res_lang WHERE code = %s\", (os.environ.get('LOAD_LANGUAGE'),))
    exists = cur.fetchone()
    if exists:
        sys.exit(0) # Existe
    else:
        sys.exit(1) # No existe
except Exception as e:
    # Si la conexion falla o la BD no existe todavia (primera ejecucion), asumimos que no existe
    # Si la BD no existe, psycopg2 va a fallar al conectar a 'odoo_db'.
    # En ese caso, Odoo la va a crear. Asi que el idioma definitivamente no existe.
    sys.exit(1)
"
}

# Instalar dependencias Python de los requirements.txt de addons (como hace Odoo.sh)
{% if addon_dirs_container is defined %}
ADDONS_DIRS="{{ addon_dirs_container | join(' ') }}"
{% else %}
ADDONS_DIRS="/mnt/extra-addons /mnt/enterprise-addons"
{% endif %}
REQ_FILES=$(find $ADDONS_DIRS -maxdepth 3 -name 'requirements.txt' -not -empty 2>/dev/null || true)
if [ -n "$REQ_FILES" ]; then
    echo "Instalando dependencias Python de los archivos requirements.txt de addons..."
    for req in $REQ_FILES; do
        pip install --break-system-packages --quiet -r "$req" 2>/dev/null || true
    done
fi

# Agregar WITHOUT_DEMO si esta seteado (v19: flag booleano, sin valor)
if [ -n "$WITHOUT_DEMO" ] && [ "$WITHOUT_DEMO" != "False" ]; then
    ARGS+=("--without-demo")
fi

# Manejo de inicializacion de modulos
MODULES_TO_INIT="${INIT_MODULES}"

# Logica de carga de idioma
if [ -n "$LOAD_LANGUAGE" ]; then
    echo "Verificando si el idioma $LOAD_LANGUAGE ya esta cargado..."
    if check_language_exists; then
        echo "El idioma $LOAD_LANGUAGE ya existe. Salteando carga."
    else
        echo "Idioma $LOAD_LANGUAGE no encontrado o BD no inicializada. Agregando flag --load-language y forzando init de base."
        ARGS+=("--load-language=${LOAD_LANGUAGE}")
        # Forzar inicializacion de 'base' para asegurar que se creen las tablas de la BD
        if [[ -z "$MODULES_TO_INIT" ]]; then
            MODULES_TO_INIT="base"
        else
            MODULES_TO_INIT="$MODULES_TO_INIT,base"
        fi
    fi
fi

# Aplicar modulos de inicializacion si hay alguno
if [ -n "$MODULES_TO_INIT" ]; then
    ARGS+=("--init=${MODULES_TO_INIT}")
fi

# Siempre agregar modo dev para hot reloading en este entorno de desarrollo
ARGS+=("--dev=reload,xml")

LOG_FILE="/var/log/odoo/odoo.log"
echo "Iniciando Odoo con comando: $CMD ${ARGS[*]}"

# Ejecutar Odoo y duplicar la salida al archivo de log manteniendo stderr para los logs de Docker.
# Usar exec para reemplazar el shell, con sustitucion de proceso para tee al archivo de log.
exec $CMD "${ARGS[@]}" > >(tee -a "$LOG_FILE") 2>&1
