# pyproject.toml del PROYECTO (no del paquete odev)
# Solo contiene configuracion de linting para los addons

[tool.ruff]
target-version = "py310"
line-length = 120
src = ["addons"]

[tool.ruff.lint]
select = ["E", "W", "F", "I", "B", "C4", "UP", "SIM"]
ignore = ["E501", "B008", "B904", "SIM108"]

[tool.ruff.lint.isort]
known-third-party = ["odoo", "odoo.addons"]

[tool.ruff.format]
quote-style = "double"

[tool.pylint.master]
load-plugins = "pylint_odoo"

[tool.pylint."messages control"]
disable = ["C0114", "C0115", "C0116", "W0104"]

[tool.pylint.odoolint]
manifest_required_authors = true
manifest_deprecated_keys = ["description", "active"]
