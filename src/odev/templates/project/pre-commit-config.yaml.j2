repos:
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v5.0.0
    hooks:
      - id: trailing-whitespace
      - id: end-of-file-fixer
      - id: check-yaml
      - id: check-added-large-files

  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.9.7
    hooks:
      - id: ruff
        args: [--fix, --exit-non-zero-on-fix]
      - id: ruff-format

  # pylint-odoo: Linter especifico para modulos Odoo
  - repo: https://github.com/OCA/pylint-odoo
    rev: v9.1.5
    hooks:
      - id: pylint_odoo
        name: pylint-odoo
        types: [python]
        args:
          - --rcfile=.pylintrc
        # Solo lint en directorios de addons, no archivos de configuracion
        files: (?:^|/)addons/.*\.py$

  # prettier: Formateo de XML (vistas Odoo)
  - repo: https://github.com/pre-commit/mirrors-prettier
    rev: v3.1.0
    hooks:
      - id: prettier
        name: prettier (XML)
        types: [xml]
        additional_dependencies:
          - "@prettier/plugin-xml@3.4.1"
