[options]
{% if addon_container_paths is defined %}
addons_path = {{ addon_container_paths | join(',') }}{% if enterprise_enabled %},/mnt/enterprise-addons{% endif %}
{% else %}
addons_path = /mnt/extra-addons{% if enterprise_enabled %},/mnt/enterprise-addons{% endif %}
{% endif %}
data_dir = /var/lib/odoo
admin_passwd = {{ ADMIN_PASSWORD | default('admin') }}
csv_internal_sep = ,
db_host = {{ DB_HOST | default('db') }}
db_port = 5432
db_user = {{ DB_USER | default('odoo') }}
db_password = {{ DB_PASSWORD | default('odoo') }}
db_name = {{ DB_NAME | default('odoo_db') }}
log_level = info
; logfile disabled — output goes to stderr (captured by Docker) and tee'd to /var/log/odoo/odoo.log via entrypoint
http_interface = 0.0.0.0
; SMTP interceptado por MailHog — todo el correo saliente se captura en http://localhost:{{ MAILHOG_PORT | default(8025) }}
smtp_server = mailhog
smtp_port = 1025
smtp_ssl = False
