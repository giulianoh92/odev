# ==========================================
# Configuracion del Entorno de Desarrollo Odoo
# ==========================================
# Generado por: odev init
# Copia este archivo como .env y ajusta los valores segun tu entorno local.

# --- Configuracion del Proyecto ---
PROJECT_NAME={{ PROJECT_NAME | default('my-odoo-project') }}
COMPOSE_PROJECT_NAME={{ PROJECT_NAME | default('my-odoo-project') }}

# --- Configuracion de Odoo ---
ODOO_VERSION={{ ODOO_VERSION | default('19.0') }}
ODOO_IMAGE=odoo:{{ ODOO_VERSION | default('19.0') | replace('.0', '') }}
WEB_PORT={{ WEB_PORT | default('8069') }}
ADMIN_PASSWORD=admin
LOAD_LANGUAGE={{ LOAD_LANGUAGE | default('en_US') }}
WITHOUT_DEMO={{ WITHOUT_DEMO | default('all') }}
DB_FILTER=^{{ DB_NAME | default('odoo_db') }}$

# --- Configuracion de Base de Datos ---
DB_IMAGE=pgvector/pgvector:pg{{ DB_IMAGE_TAG | default('16') }}
DB_PORT={{ DB_PORT | default('5432') }}
DB_NAME={{ DB_NAME | default('odoo_db') }}
DB_USER=odoo
DB_PASSWORD=odoo
DB_HOST=db

# --- Configuracion Extra ---
PGWEB_PORT={{ PGWEB_PORT | default('8081') }}
DEBUGPY=False
DEBUGPY_PORT={{ DEBUGPY_PORT | default('5678') }}
INIT_MODULES=
